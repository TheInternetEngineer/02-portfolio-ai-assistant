# Copy this file to .env and fill in real values. Never commit .env itself.

# OpenAI: used for both embeddings (indexing + question) and the chat completion
OPENAI_API_KEY=

# Pinecone: vector store holding the embedded content chunks
PINECONE_API_KEY=
PINECONE_INDEX_NAME=portfolio-ai-assistant

# CORS: the origin(s) allowed to call this API from the browser.
# Local dev + your production site domain, comma separated.
ALLOWED_ORIGINS=http://localhost:3000

# Path to the website repo's content folder, used by scripts/build_index.py
# to find the MDX files to index. Points at project 01 on disk.
WEBSITE_CONTENT_DIR=../01-portfolio-website/content
